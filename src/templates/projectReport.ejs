<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>تقرير مشروع - <%= project.title %></title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1e3a8a;
            --secondary: #b45309;
            --accent: #0f172a;
            --success: #059669;
            --danger: #dc2626;
            --warning: #d97706;
            --bg: #f8fafc;
            --card-bg: #ffffff;
            --border: #e2e8f0;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            line-height: 1.6;
            padding: 40px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid var(--primary);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .logo-container img {
            max-height: 100px;
            object-fit: contain;
        }

        .report-info {
            text-align: left;
        }

        .report-info h1 {
            color: var(--primary);
            font-size: 28px;
            margin-bottom: 5px;
        }

        .report-info p {
            color: var(--text-muted);
            font-size: 14px;
        }

        .section-title {
            color: var(--primary);
            font-size: 20px;
            font-weight: 700;
            margin: 30px 0 20px;
            padding-right: 15px;
            border-right: 5px solid var(--primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .grid-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            border: 1px solid var(--border);
            text-align: center;
        }

        .stat-label {
            display: block;
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .stat-value {
            display: block;
            font-size: 18px;
            font-weight: 700;
            color: var(--accent);
        }

        .description-box {
            background: #f1f5f9;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 30px;
            font-size: 14px;
            color: var(--text-main);
        }

        .charts-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .chart-box {
            background: var(--card-bg);
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border);
        }

        .chart-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            text-align: center;
            color: var(--primary);
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border);
            margin-bottom: 30px;
        }

        th {
            background-color: var(--primary);
            color: white;
            padding: 15px;
            text-align: right;
            font-size: 14px;
            font-weight: 600;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:nth-child(even) {
            background-color: #f1f5f9;
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .status-approved { background: #d1fae5; color: #065f46; }
        .status-pending { background: #fef3c7; color: #92400e; }
        .status-rejected { background: #fee2e2; color: #991b1b; }

        .severity-badge {
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 10px;
            color: white;
        }
        .severity-عالي { background: var(--danger); }
        .severity-حرج { background: #7f1d1d; }
        .severity-متوسط { background: var(--warning); }
        .severity-منخفض { background: var(--success); }

        .company-profile {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 20px;
            background: white;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .footer {
            margin-top: 50px;
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 12px;
        }

        .page-break {
            page-break-before: always;
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="logo-container">
            <% if (logo) { %>
                <img src="data:image/png;base64,<%= logo %>" alt="NSPO Logo">
            <% } %>
        </div>
        <div class="report-info">
            <h1>تقرير تفصيلي للمشروع</h1>
            <p>تاريخ الاستخراج: <%= new Date().toLocaleDateString('ar-EG') %></p>
            <p>كود المشروع: #<%= project._id.toString().slice(-6).toUpperCase() %></p>
        </div>
    </div>

    <div class="section-title">بيانات المشروع الأساسية</div>
    <div class="grid-stats">
        <div class="stat-card">
            <span class="stat-label">اسم المشروع</span>
            <span class="stat-value"><%= project.title %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">القطاع</span>
            <span class="stat-value"><%= project.sectorId ? project.sectorId.name : 'غير محدد' %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">الجهة المنفذة</span>
            <span class="stat-value"><%= project.companyId ? (project.companyId.name_ar || project.companyId.name) : 'غير محدد' %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">الجهة المستفيدة</span>
            <span class="stat-value"><%= project.beneficiaryEntity || 'غير محدد' %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">تاريخ أو موعد المشروع</span>
            <span class="stat-value"><%= project.projectDate || 'غير محدد' %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">تاريخ البدء المعتمد</span>
            <span class="stat-value"><%= formatDate(project.startDate) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">تاريخ التسليم المتوقع</span>
            <span class="stat-value"><%= formatDate(project.endDate) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">حالة المشروع</span>
            <span class="stat-value"><%= project.status %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">نسبة الإنجاز</span>
            <span class="stat-value"><%= project.completionPercentage || 0 %>%</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">أُنشئ بواسطة</span>
            <span class="stat-value"><%= project.createdBy ? project.createdBy.name : 'غير محدد' %></span>
        </div>
    </div>

    <div class="description-box">
        <strong>وصف وأهداف المشروع:</strong><br>
        <%= project.description || 'لا يوجد وصف' %>
    </div>

    <div class="description-box">
        <strong>تفاصيل التنفيذ والعمل الجاري:</strong><br>
        <%= project.executionDetails || 'لا توجد تفاصيل تنفيذ مسجلة حالياً.' %>
    </div>

    <% if (project.projectLocation) { %>
    <div style="margin-bottom: 20px; font-size: 13px; color: var(--text-main); font-weight: bold;">
        📍 موقع المشروع: <%= project.projectLocation %>
    </div>
    <% } %>

    <% if (project.location && project.location.coordinates) { %>
    <div style="margin-bottom: 20px; font-size: 12px; color: var(--text-muted);">
        📍 الإحداثيات الجغرافية: [<%= project.location.coordinates[0] %>, <%= project.location.coordinates[1] %>]
    </div>
    <% } %>

    <div class="section-title">الملخص المالي</div>
    <div class="grid-stats">
        <div class="stat-card">
            <span class="stat-label">إجمالي الميزانية</span>
            <span class="stat-value" style="color: var(--primary);"><%= formatMoney(project.totalBudget || 0) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">الميزانية المخصصة</span>
            <span class="stat-value"><%= formatMoney(project.allocatedBudget || 0) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">إجمالي التمويل المعتمد</span>
            <span class="stat-value"><%= formatMoney(totalFundingCommitted) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">إجمالي المبالغ المستلمة</span>
            <span class="stat-value"><%= formatMoney(totalFundingReceived) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">إجمالي المنصرف</span>
            <span class="stat-value"><%= formatMoney(totalSpent) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">مصروفات قيد الانتظار</span>
            <span class="stat-value"><%= formatMoney(pendingSpent) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">المتبقي</span>
            <span class="stat-value"><%= formatMoney(remaining) %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label">نسبة الصرف</span>
            <span class="stat-value"><%= spendingPercentage %>%</span>
        </div>
    </div>

    <% if (budgetsList && budgetsList.length > 0) { %>
    <div class="section-title">الميزانية حسب العملة</div>
    <table>
        <thead>
            <tr>
                <th>العملة</th>
                <th>المبلغ المعتمد</th>
            </tr>
        </thead>
        <tbody>
            <% budgetsList.forEach(b => { %>
                <tr>
                    <td><%= b.currency %></td>
                    <td><%= formatMoney(b.amount, b.currency) %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <% } %>

    <div class="section-title">مصادر التمويل والدفعات</div>
    <% if (project.funding && project.funding.length > 0) { %>
        <% project.funding.forEach(f => { %>
            <div style="background: white; border: 1px solid var(--border); border-radius: 12px; margin-bottom: 20px; overflow: hidden;">
                <div style="background: #f8fafc; padding: 15px; border-bottom: 1px solid var(--border);">
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                        <div>
                            <strong><%= f.sourceName %></strong>
                            <span style="background: #dbeafe; color: #1d4ed8; padding: 2px 8px; border-radius: 4px; font-size: 11px; margin-right: 8px;"><%= f.sourceType %></span>
                            <% if (f.currency) { %>
                                <span style="font-size: 11px; color: var(--text-muted);">(<%= f.currency %>)</span>
                            <% } %>
                        </div>
                        <span style="font-size: 12px; font-weight: 600;"><%= f.status || 'غير محدد' %></span>
                    </div>
                    <% if (f.description) { %>
                        <p style="font-size: 12px; color: var(--text-muted); margin-top: 8px;"><%= f.description %></p>
                    <% } %>
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 12px; font-size: 12px;">
                        <div>المبلغ المعتمد: <strong><%= formatMoney(f.committedAmount, f.currency || 'EGP') %></strong></div>
                        <div>المستلم: <strong style="color: var(--success);"><%= formatMoney(f.receivedAmount, f.currency || 'EGP') %></strong></div>
                        <div>المتبقي: <strong><%= formatMoney(f.remainingAmount, f.currency || 'EGP') %></strong></div>
                    </div>
                </div>
                <table style="margin-bottom: 0; border: none; border-radius: 0;">
                    <thead>
                        <tr>
                            <th>تاريخ الدفعة</th>
                            <th>رقم المرجع</th>
                            <th>طريقة الدفع</th>
                            <th>القيمة</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (f.transactions && f.transactions.length > 0) { %>
                            <% f.transactions.forEach(t => { %>
                                <tr>
                                    <td><%= formatDate(t.transactionDate) %></td>
                                    <td><%= t.referenceNumber || '---' %></td>
                                    <td><%= t.paymentMethod || '---' %></td>
                                    <td><%= formatMoney(t.amount, t.currency || f.currency || 'EGP') %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align: center; color: var(--text-muted);">لا توجد دفعات مسجلة بعد</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% }) %>
    <% } else { %>
        <table>
            <tbody>
                <tr>
                    <td style="text-align: center; color: var(--text-muted); padding: 20px;">لا توجد بيانات تمويل مسجلة حالياً</td>
                </tr>
            </tbody>
        </table>
    <% } %>

    <div class="charts-container">
        <div class="chart-box">
            <h3 class="chart-title">توزيع المنصرف الفعلي</h3>
            <canvas id="categoryChart"></canvas>
        </div>
        <div class="chart-box">
            <h3 class="chart-title">مقارنة المخطط بالفعلي</h3>
            <canvas id="budgetChart"></canvas>
        </div>
    </div>

    <div class="section-title">تفاصيل بنود الميزانية</div>
    <table>
        <thead>
            <tr>
                <th>البند / الفئة</th>
                <th>المبلغ المخطط</th>
                <th>المبلغ الفعلي</th>
                <th>الانحراف (Variance)</th>
            </tr>
        </thead>
        <tbody>
            <% if ((project.budgetBreakdown || []).length > 0) { %>
                <% project.budgetBreakdown.forEach(item => { %>
                    <tr>
                        <td><%= item.category %></td>
                        <td><%= formatMoney(item.plannedAmount || 0) %></td>
                        <td><%= formatMoney(item.actualAmount || 0) %></td>
                        <td style="color: <%= (item.variance || 0) < 0 ? 'var(--danger)' : 'var(--success)' %>">
                            <%= formatMoney(item.variance || 0) %>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="4" style="text-align: center; color: var(--text-muted);">لا توجد بيانات للعرض</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <div class="section-title">سجل المصروفات التفصيلي</div>
    <table>
        <thead>
            <tr>
                <th>التاريخ</th>
                <th>الفئة</th>
                <th>البيان</th>
                <th>المورد</th>
                <th>القيمة</th>
                <th>الحالة</th>
            </tr>
        </thead>
        <tbody>
            <% if (allExpenses && allExpenses.length > 0) { %>
                <% allExpenses.forEach(expense => { %>
                    <tr>
                        <td><%= formatDate(expense.date) %></td>
                        <td><%= expense.category %></td>
                        <td><%= expense.description || '---' %></td>
                        <td><%= expense.vendor %></td>
                        <td><%= formatMoney(expense.amount, expense.currency || 'EGP') %></td>
                        <td>
                            <span class="status-badge <%= expense.status === 'معتمد' ? 'status-approved' : expense.status === 'قيد الانتظار' ? 'status-pending' : 'status-rejected' %>">
                                <%= expense.status %>
                            </span>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" style="text-align: center; color: var(--text-muted);">لا توجد سجلات مصروفات لهذا المشروع</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <div class="page-break"></div>

    <div class="section-title">سجل المخاطر</div>
    <table>
        <thead>
            <tr>
                <th>وصف الخطر</th>
                <th>الخطورة</th>
                <th>خطة التخفيف</th>
                <th>الحالة</th>
            </tr>
        </thead>
        <tbody>
            <% if ((project.risks || []).length > 0) { %>
                <% project.risks.forEach(risk => { %>
                    <tr>
                        <td><%= risk.description %></td>
                        <td><span class="severity-badge severity-<%= risk.severity %>"><%= risk.severity %></span></td>
                        <td><%= risk.mitigationPlan || '---' %></td>
                        <td><%= risk.status %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="4" style="text-align: center; color: var(--text-muted);">لا توجد مخاطر مسجلة لهذا المشروع</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <div class="section-title">عقود التمويل والتنفيذ</div>
    <% if (contracts && contracts.length > 0) { %>
        <% contracts.forEach(contract => { %>
            <div style="background: white; border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                    <div>
                        <h4 style="font-size: 16px; margin-bottom: 4px;"><%= contract.contractorName %></h4>
                        <% if (contract.description) { %>
                            <p style="font-size: 12px; color: var(--text-muted);"><%= contract.description %></p>
                        <% } %>
                    </div>
                    <% if (contract.status) { %>
                        <span style="font-size: 11px; background: #d1fae5; color: #065f46; padding: 4px 10px; border-radius: 12px;"><%= contract.status %></span>
                    <% } %>
                </div>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; font-size: 13px; margin-bottom: 15px;">
                    <div>قيمة العقد: <strong><%= formatMoney(contract.contractValue) %></strong></div>
                    <div>المدفوع: <strong style="color: var(--success);"><%= formatMoney(contract.paidAmount) %></strong></div>
                    <div>المتبقي: <strong><%= formatMoney(contract.remainingAmount) %></strong></div>
                </div>
                <% if (contract.images && contract.images.length > 0) { %>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <% contract.images.forEach(img => { %>
                            <img src="<%= img %>" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border);">
                        <% }) %>
                    </div>
                <% } %>
            </div>
        <% }) %>
    <% } else { %>
        <table>
            <tbody>
                <tr>
                    <td style="text-align: center; color: var(--text-muted); padding: 20px;">لا توجد عقود مسجلة</td>
                </tr>
            </tbody>
        </table>
    <% } %>

    <div class="section-title">بيانات الشركة المنفذة</div>
    <div class="company-profile">
        <div>
            <% if (project.companyId && project.companyId.logo) { %>
                <img src="<%= project.companyId.logo %>" alt="Company Logo" style="width: 100%; border-radius: 8px;">
            <% } %>
            <div style="margin-top: 10px; font-weight: 700; text-align: center;">
                <%= project.companyId ? (project.companyId.name_ar || project.companyId.name) : 'غير محدد' %>
            </div>
        </div>
        <div>
            <p style="font-size: 13px;"><strong>عن الشركة:</strong> <%= project.companyId && project.companyId.details ? project.companyId.details.description_ar : 'لا يوجد وصف متاح' %></p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; font-size: 12px;">
                <div>📞 هاتف: <%= project.companyId && project.companyId.details && project.companyId.details.contact ? project.companyId.details.contact.phone : '-' %></div>
                <div>🌐 الموقع: <%= project.companyId && project.companyId.details ? project.companyId.details.website : '-' %></div>
                <div>📅 التأسيس: <%= project.companyId && project.companyId.details ? project.companyId.details.establishment_year : '-' %></div>
                <div>🏭 المصانع: <%= project.companyId ? project.companyId.number_of_factories : '-' %></div>
            </div>
            <div style="margin-top: 15px;">
                <strong>المنتجات الرئيسية:</strong><br>
                <div style="display: flex; gap: 5px; flex-wrap: wrap; margin-top: 5px;">
                    <% if (project.companyId && project.companyId.details && project.companyId.details.products_ar) { %>
                        <% project.companyId.details.products_ar.forEach(p => { %>
                            <span style="background: #e2e8f0; padding: 2px 8px; border-radius: 4px; font-size: 11px;"><%= p %></span>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <% if (project.images && project.images.length > 0) { %>
        <div class="section-title">معرض صور المشروع</div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 30px;">
            <% project.images.forEach(img => { %>
                <img src="<%= img %>" style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border);">
            <% }) %>
        </div>
    <% } %>

    <div class="footer">
        <p>صدر هذا التقرير آلياً من منصة إدارة مشاريع الجهاز - جميع الحقوق محفوظة</p>
    </div>

    <script>
        // Category Distribution Chart
        const ctxCategory = document.getElementById('categoryChart').getContext('2d');
        new Chart(ctxCategory, {
            type: 'doughnut',
            data: {
                labels: <%- JSON.stringify(categoryLabels) %>,
                datasets: [{
                    data: <%- JSON.stringify(categoryData) %>,
                    backgroundColor: [
                        '#1e3a8a', '#3b82f6', '#60a5fa', '#93c5fd', '#bfdbfe', '#1d4ed8'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { family: 'Cairo' } } }
                }
            }
        });

        // Budget vs Actual Chart
        const ctxBudget = document.getElementById('budgetChart').getContext('2d');
        new Chart(ctxBudget, {
            type: 'bar',
            data: {
                labels: <%- JSON.stringify(breakdownLabels) %>,
                datasets: [
                    {
                        label: 'مخطط',
                        data: <%- JSON.stringify(breakdownData) %>,
                        backgroundColor: 'rgba(30, 58, 138, 0.2)',
                        borderColor: '#1e3a8a',
                        borderWidth: 1
                    },
                    {
                        label: 'فعلي',
                        data: <%- JSON.stringify(categoryData) %>,
                        backgroundColor: '#1e3a8a',
                        borderColor: '#1e3a8a',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true }
                },
                plugins: {
                    legend: { position: 'bottom', labels: { font: { family: 'Cairo' } } }
                }
            }
        });
    </script>
</body>
</html>
